---
# GridShield clang-tidy configuration
#
# These checks run in CI via .github/workflows/build.yml.
# The compile_commands.json is sanitized by scripts/fix_compile_commands.py
# before clang-tidy is invoked (removes Xtensa GCC-specific flags).

Checks: >
  -*,
  bugprone-*,
  performance-*,
  readability-*,
  modernize-*,
  -modernize-use-trailing-return-type

WarningsAsErrors: 'bugprone-*'

HeaderFilterRegex: '^(main/.*|include/.*)'