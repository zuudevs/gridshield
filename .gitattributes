# Default behavior: auto-detect text files and normalize line endings
* text=auto

# Ensure shell scripts always use LF (Linux/macOS compatibility)
*.sh text eol=lf

# Ensure PowerShell scripts always use CRLF (Windows compatibility)
*.ps1 text eol=crlf

# Treat binaries as binary data
*.bin binary
*.hex binary
*.elf binary
*.map binary

# Graphics and documents
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.docx binary
*.xlsx binary
